<Window x:Class="ChessGame.Client.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChessGame.Client.Views"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="800">
    <Window.Resources>
        <!-- 定义按钮样式 -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Cornsilk"/>
            <!-- 默认背景色 -->
            <Setter Property="Foreground" Value="DarkGoldenrod"/>
            <!-- 文字颜色 -->
            <Setter Property="BorderBrush" Value="DarkGoldenrod"/>
            <!-- 边框颜色 -->
            <Setter Property="BorderThickness" Value="2"/>
            <!-- 边框厚度 -->
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                        CornerRadius="10" 
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="5" BlurRadius="10" Opacity="0.3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 鼠标悬停效果 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Wheat"/>
                                <Setter Property="BorderBrush" Value="DarkGoldenrod"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="7" BlurRadius="15" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <!-- 按下效果 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="Wheat"/>
                                <Setter Property="BorderBrush" Value="Tan"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" BlurRadius="5" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height = "1*" />
            <RowDefinition Height = "6*" />

        </Grid.RowDefinitions>

        <Grid Grid.Row = "0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width = "2*" />
                <ColumnDefinition Width = "1*" />
                <ColumnDefinition Width = "2*" />
                <ColumnDefinition Width = "14*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse Fill="Black" />
                <!-- 黑色背景，可选 -->
                <Ellipse Stroke="Black" StrokeThickness="1" />
                <!-- 边框 -->
                <Image Source="pack://application:,,,/source/picture1.png" Stretch="UniformToFill">
                    <Image.Clip>
                        <EllipseGeometry Center="30,30" RadiusX="30" RadiusY="30"/>
                    </Image.Clip>
                </Image>
            </Grid>

            <Grid Grid.Column = "1">
                <Grid.RowDefinitions>
                    <RowDefinition Height = "1*" />
                    <RowDefinition Height = "1*" />
                </Grid.RowDefinitions>
                <TextBox Grid.Row = "0" Text = "昵称" FontFamily="FZYaoTi" Foreground="Sienna" FontSize = "15" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
                <TextBox Grid.Row = "1" Text = "积分" FontFamily="FZYaoTi" Foreground="Sienna" FontSize = "15" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
            </Grid>

            <Grid Grid.Column = "3">
                <TextBlock Text = "Alpha Billionaire" FontFamily="FZYaoTi" Foreground="Sienna" FontSize = "50" Margin = "30,15,220,5" VerticalAlignment = "Center" />
            </Grid>

        </Grid>

        <Grid Grid.Row = "1">
            <Grid.RowDefinitions>
                <RowDefinition Height = "1*" />
                <RowDefinition Height = "1*" />
                <RowDefinition Height = "1*" />
                <RowDefinition Height = "1*" />
                <RowDefinition Height = "1*" />
                <RowDefinition Height = "1*" />
            </Grid.RowDefinitions>

            <Button Grid.Row = "1" Style="{StaticResource ModernButtonStyle}" Height = "80" Width = "200" Content = "人机模式" FontFamily="FZYaoTi" FontSize = "32" VerticalAlignment = "Center" HorizontalAlignment = "Center" Click = "ManMachineMode_Click"/>
            <Button Grid.Row = "2" Style="{StaticResource ModernButtonStyle}" Height = "80" Width = "200" Content = "联机模式" FontFamily="FZYaoTi" FontSize = "32" VerticalAlignment = "Center" HorizontalAlignment = "Center" Click = "OnlineMode_Click"/>
            <Button Grid.Row = "3" Style="{StaticResource ModernButtonStyle}" Height = "80" Width = "200" Content = "排行榜" FontFamily="FZYaoTi" FontSize = "32" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
            <Button Grid.Row = "4" Style="{StaticResource ModernButtonStyle}" Height = "80" Width = "200" Content = "testButton" FontFamily="FZYaoTi" FontSize = "32" VerticalAlignment = "Center" HorizontalAlignment = "Center" Click = "Button_Click" />
        </Grid>

    </Grid>
</Window>
