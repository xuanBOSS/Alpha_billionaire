<Window x:Class="ChessGame.Client.Views.GameView"
        x:Name = "GameView1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChessGame.Client.Views"
        mc:Ignorable="d"
        Title = "GameView" Height = "700" Width = "900"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Grid>
        <Grid.RowDefinitions>
            <!--第一行显示标题-->
            <RowDefinition Height = "1*" />
            <!--第二行显示棋盘及胜率-->
            <RowDefinition Height = "7*" />
        </Grid.RowDefinitions>

        <!--第一行-->
        <!--标题联机模式-->
        <TextBlock Grid.Row = "0" Text = "联机模式" FontSize = "50" HorizontalAlignment="Center" VerticalAlignment = "Center" />

        <!--第二行-->
        <Grid Grid.Row = "1">
            <Grid.ColumnDefinitions>
                <!--第一列显示棋盘-->
                <ColumnDefinition Width = "5*" />
                <!--第二列显示玩家信息及胜率-->
                <ColumnDefinition Width = "2*" />
            </Grid.ColumnDefinitions>

            <!--棋盘-->
            <!--棋盘背景-->
            <Border Width = "490" Height = "490" Background = "LightGray" HorizontalAlignment = "Center" VerticalAlignment = "Center">
                <!--棋盘网格-->
                <Canvas x:Name="BoardCanvas" >
                    <!--五个星位点-->
                    <Ellipse Canvas.Left = "100" Canvas.Top = "100" Width = "10" Height = "10" Fill = "Black" />
                    <Ellipse Canvas.Left = "380" Canvas.Top = "100" Width = "10" Height = "10" Fill = "Black" />
                    <Ellipse Canvas.Left = "240" Canvas.Top = "240" Width = "10" Height = "10" Fill = "Black" />
                    <Ellipse Canvas.Left = "100" Canvas.Top = "380" Width = "10" Height = "10" Fill = "Black" />
                    <Ellipse Canvas.Left = "380" Canvas.Top = "380" Width = "10" Height = "10" Fill = "Black" />
                </Canvas>
            </Border>

            <!--显示玩家昵称积分和实时胜率-->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height = "1*" />
                    <RowDefinition Height = "1*" />
                    <RowDefinition Height = "1*" />
                    <RowDefinition Height = "1*" />
                    <RowDefinition Height = "1*" />
                    <RowDefinition Height = "1*" />
                    <RowDefinition Height = "1*" />
                    <RowDefinition Height = "1*" />
                </Grid.RowDefinitions>

                <!--玩家A信息-->
                <Grid Grid.Row = "1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width = "1*" />
                        <ColumnDefinition Width = "1*" />
                        <ColumnDefinition Width = "1*" />
                        <ColumnDefinition Width = "1*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column = "1">
                        <!--昵称和积分-->
                        <Grid.RowDefinitions>
                            <RowDefinition Height = "1*" />
                            <RowDefinition Height = "1*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row = "0" Text = "昵称" FontSize = "15" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
                        <TextBlock Grid.Row = "1" Text = "积分" FontSize = "15" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
                    </Grid>

                    <Grid Grid.Column = "2">
                        <!--实际昵称和积分显示-->
                        <Grid.RowDefinitions>
                            <RowDefinition Height = "1*" />
                            <RowDefinition Height = "1*" />
                        </Grid.RowDefinitions>
                        <TextBox Grid.Row = "0" Text = "昵称" FontSize = "15" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
                        <TextBox Grid.Row = "1" Text = "积分" FontSize = "15" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
                    </Grid>
                </Grid>

                <!--玩家A胜率-->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width = "1*" />
                        <ColumnDefinition Width = "4*" />
                        <ColumnDefinition Width = "1*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text = "胜率" FontSize = "15" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
                    <!--进度条-->
                    <ProgressBar Grid.Column="1" VerticalAlignment = "Center" HorizontalAlignment = "Left" Width="200" Height="30"/>
                </Grid>

                <!--玩家B玩家信息-->
                <Grid Grid.Row = "4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width = "1*" />
                        <ColumnDefinition Width = "1*" />
                        <ColumnDefinition Width = "1*" />
                        <ColumnDefinition Width = "1*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column = "1">
                        <!--昵称和积分-->
                        <Grid.RowDefinitions>
                            <RowDefinition Height = "1*" />
                            <RowDefinition Height = "1*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row = "0" Text = "昵称" FontSize = "15" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
                        <TextBlock Grid.Row = "1" Text = "积分" FontSize = "15" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
                    </Grid>
                </Grid>

                <!--玩家B胜率-->
                <Grid Grid.Row="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width = "1*" />
                        <ColumnDefinition Width = "4*" />
                        <ColumnDefinition Width = "1*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text = "胜率" FontSize = "15" VerticalAlignment = "Center" HorizontalAlignment = "Center" />
                    <!--进度条-->
                    <ProgressBar Grid.Column="1" VerticalAlignment = "Center" HorizontalAlignment = "Left" Width="200" Height="30"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>

